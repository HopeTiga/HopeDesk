QListWidget {
    background: #F5F7FA;
    border: none;
    outline: none;
    padding: 10px;
}
QListWidget::item {
    height: 60px;
    color: #2C3E50;
    border-bottom: 1px solid #E1E8ED;
    padding-left: 5px;
}
QListWidget::item:hover {
    background: #FFFFFF;
    border-radius: 6px;
    border-bottom: 1px solid transparent;
}
QListWidget::item:selected {
    background: #F0F7FF;
    border-radius: 6px;
    border: 1px solid #00B4FF;
}
</string>
