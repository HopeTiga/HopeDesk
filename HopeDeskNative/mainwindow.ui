  <property name="styleSheet">
   <string notr="true">
/* 全局设定 - ToDesk 风格蓝白主题 */
QMainWindow {
    background-color: #F5F7FA;
    color: #333333;
    font-family: &quot;Microsoft YaHei UI&quot;, &quot;Segoe UI&quot;, sans-serif;
}
QWidget { outline: none; }

/* 滚动条 */
QScrollBar:vertical {
    border: none;
    background: transparent;
    width: 6px;
    margin: 0px;
}
QScrollBar::handle:vertical {
    background: #D0D8E0;
    min-height: 20px;
    border-radius: 3px;
}
QScrollBar::handle:vertical:hover { background: #B0BCC8; }
QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical { height: 0px; }

/* 通用去边框 */
QFrame { border: none; }

/* 提示框 */
QToolTip {
    background-color: #FFFFFF;
    color: #333333;
    border: 1px solid #E1E8ED;
    padding: 5px;
    border-radius: 4px;
}
</string>
