QFrame#frameSettingCard {
    background-color: #26282D;
    border-radius: 8px;
    padding: 20px;
}
QCheckBox {
    color: #DCDCDC;
    font-size: 14px;
    spacing: 10px;
}
QCheckBox::indicator {
    width: 16px;
    height: 16px;
    border-radius: 3px;
    border: 1px solid #606266;
    background: transparent;
}
QCheckBox::indicator:checked {
    background-color: #409EFF;
    border-color: #409EFF;
}
QLabel {
    color: #DCDCDC;
    font-size: 14px;
}
QComboBox {
    background-color: #313338;
    border: 1px solid #45474D;
    border-radius: 4px;
    padding: 5px 10px;
    color: #FFFFFF;
    font-size: 13px;
    min-width: 120px;
}
QComboBox:hover {
    border: 1px solid #606266;
}
QComboBox::drop-down {
    border: none;
    width: 20px;
}
</string>
