             <string notr="true">
QListWidget {
    background: #1E1F22;
    border: none;
    outline: none;
    padding: 10px;
}
QListWidget::item {
    height: 60px;
    color: #F3F4F6;
    border-bottom: 1px solid #2C2E33;
    padding-left: 5px;
}
QListWidget::item:hover {
    background: #26282D;
    border-radius: 6px;
    border-bottom: 1px solid transparent;
}
QListWidget::item:selected {
    background: #2B2D30;
    border-radius: 6px;
    border: 1px solid #3B82F6;
}
</string>
